# ─────────────────────────────────────────────
# Data — commit curated outputs only
# ─────────────────────────────────────────────
data/raw/
data/bronze/
data/silver/
data/gold/
data/quarantine/
data/*.parquet
data/*.csv
data/*.duckdb
data/*.duckdb.wal

# Allow exported outputs to be versioned
!data/output/
!data/output/**

# Keep large generated archives in output ignored
data/output/*.zip

# Keep the data/ folder structure visible to collaborators
!data/.gitkeep
!data/README.md

